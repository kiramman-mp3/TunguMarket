# Configuración de Base de Datos
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tungumarket

# Configuración del Backend
PORT=5000
JWT_SECRET=super_secret_jwt_key_here

# Configuración de pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin

# Configuración de Mobile
# IMPORTANTE: Cambia esta IP a tu dirección IPv4 local (ej. 192.168.1.15) para que Expo Go conecte correctamente
REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.X

# Credenciales de Expo
EXPO_TOKEN=your_expo_access_token_here
# Contraseña depreciada
